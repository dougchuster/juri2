model Documento {
  id               String  @id @default(cuid())
  processoId       String?
  pastaId          String?
  categoriaId      String?
  escritorioId     String?
  versaoAtualId    String? @unique
  versaoPublicadaId String? @unique

  titulo          String
  conteudo        String? @db.Text
  arquivoUrl      String?
  arquivoNome     String?
  arquivoTamanho  Int?
  mimeType        String?
  versao          Int                  @default(1)
  statusFluxo     StatusFluxoDocumento @default(RASCUNHO)
  bloqueadoEm     DateTime?
  bloqueadoMotivo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processo        Processo?                   @relation(fields: [processoId], references: [id], onDelete: Cascade)
  pasta           PastaDocumento?             @relation(fields: [pastaId], references: [id], onDelete: SetNull)
  categoria       CategoriaDocumento?         @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  escritorio      Escritorio?                 @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  versaoAtual     DocumentoVersao?            @relation("DocumentoVersaoAtual", fields: [versaoAtualId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  versaoPublicada DocumentoVersao?            @relation("DocumentoVersaoPublicada", fields: [versaoPublicadaId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  versoes         DocumentoVersao[]           @relation("DocumentoVersoes")
  comentariosRevisao DocumentoComentarioRevisao[]

  @@index([processoId])
  @@index([pastaId])
  @@index([categoriaId])
  @@index([escritorioId])
  @@index([statusFluxo])
  @@map("documentos")
}

enum StatusFluxoDocumento {
  RASCUNHO
  EM_REVISAO
  APROVADA
  PUBLICADA
}

enum OrigemVersaoDocumento {
  CRIACAO
  IMPORTACAO
  ANEXO_PROCESSO
  EDICAO
  RESTAURACAO
}

model DocumentoVersao {
  id                   String                @id @default(cuid())
  documentoId          String
  numero               Int
  statusFluxo          StatusFluxoDocumento  @default(RASCUNHO)
  origem               OrigemVersaoDocumento @default(CRIACAO)
  titulo               String
  conteudo             String?               @db.Text
  arquivoUrl           String?
  arquivoNome          String?
  arquivoTamanho       Int?
  mimeType             String?
  categoriaId          String?
  categoriaNome        String?
  pastaId              String?
  pastaNome            String?
  resumoAlteracoes     String?               @db.Text
  restauradaDaVersaoId String?
  criadoPorUserId      String?
  criadoPorNome        String?
  publicadaEm          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  documento Documento @relation("DocumentoVersoes", fields: [documentoId], references: [id], onDelete: Cascade)
  restauradaDaVersao DocumentoVersao? @relation("DocumentoVersaoRestauradaDe", fields: [restauradaDaVersaoId], references: [id], onDelete: SetNull)
  restauracoes DocumentoVersao[] @relation("DocumentoVersaoRestauradaDe")
  comentariosRevisao DocumentoComentarioRevisao[]
  documentosComoVersaoAtual Documento[] @relation("DocumentoVersaoAtual")
  documentosComoVersaoPublicada Documento[] @relation("DocumentoVersaoPublicada")

  @@unique([documentoId, numero])
  @@index([documentoId, createdAt])
  @@index([statusFluxo])
  @@map("documento_versoes")
}

model DocumentoComentarioRevisao {
  id          String   @id @default(cuid())
  documentoId String
  versaoId    String
  autorUserId String?
  autorNome   String?
  conteudo    String   @db.Text
