model LogAuditoria {
  id          String   @id @default(cuid())
  userId      String
  acao        String
  entidade    String
  entidadeId  String
  dadosAntes  Json?
  dadosDepois Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

