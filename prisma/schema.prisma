// =============================================================
// prisma/schema.prisma
// Sistema Jurídico — Database Schema
// =============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// Ã°Å¸â€Â AUTENTICAÇÃO & USUÁRIOS
// =============================================================

enum Role {
  ADMIN
  SOCIO
  ADVOGADO
  CONTROLADOR
  ASSISTENTE
  FINANCEIRO
  SECRETARIA
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(ADVOGADO)
  avatarUrl    String?
  whatsapp     String?
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions                      Session[]
  mfaConfig                     UserMfaConfig?
  mfaSetupChallenge             MfaSetupChallenge?
  mfaLoginChallenges            MfaLoginChallenge[]
  recoveryCodes                 UserRecoveryCode[]
  trustedDevices                MfaTrustedDevice[]
  advogado                      Advogado?
  logs                          LogAuditoria[]
  jobExecutionAttemptsTriggered JobExecutionAttempt[]
  notifications                 Notificacao[]
  assignedConversations         Conversation[]
  legalAgentConversations       LegalAgentConversation[]
  atribuicoesProcessoExecutadas ProcessoAtribuicaoLog[]  @relation("ProcessoAtribuicaoExecutadaPor")
  crmOwnedCards                 CRMCard[]                @relation("CRMCardOwner")
  crmActivities                 CRMActivity[]            @relation("CRMActivityOwner")
  crmStageTransitions           CRMStageTransition[]     @relation("CRMStageChangedBy")
  crmLgpdEvents                 CRMLGPDEvent[]           @relation("CRMLGPDRequestedBy")
  lgpdRequestsOpened            LgpdRequest[]           @relation("LgpdRequestRequestedBy")
  lgpdRequestsAssigned          LgpdRequest[]           @relation("LgpdRequestAssignedTo")
  lgpdDataExportsGenerated      LgpdDataExport[]        @relation("LgpdDataExportGeneratedBy")
  retentionPoliciesCreated      RetentionPolicy[]       @relation("RetentionPolicyCreatedBy")
  retentionPoliciesUpdated      RetentionPolicy[]       @relation("RetentionPolicyUpdatedBy")
  retentionExecutionsTriggered  RetentionExecution[]    @relation("RetentionExecutionTriggeredBy")
  crmCommercialDocuments        CRMCommercialDocument[]  @relation("CRMDocumentCreatedBy")
  crmConflictDecisions          CRMConflictCheck[]       @relation("CRMConflictDecidedBy")
  funcionarioFinanceiro         FuncionarioFinanceiro?
  financeiroLancamentosCriados  FinanceiroEscritorioLancamento[] @relation("FinanceiroEscritorioCriadoPor")
  casosFinanceirosCriados       CasoFinanceiro[]                 @relation("CasoFinanceiroCriadoPor")
  repassesAprovados             RepasseHonorario[]               @relation("RepasseAprovadoPor")
  repassesFuncionario           RepasseHonorario[]               @relation("RepasseFuncionario")
  internalChatCreatedConversations InternalChatConversation[]    @relation("InternalChatCreatedBy")
  internalChatParticipants        InternalChatParticipant[]
  internalChatMessages            InternalChatMessage[]          @relation("InternalChatMessageSender")
  internalChatReads               InternalChatRead[]
  internalChatPresence            InternalChatPresence?

  // Agenda (novo modulo)
  agendamentosCriados          Agendamento[]           @relation("AgendamentoCriadoPor")
  agendamentosConferidos       Agendamento[]           @relation("AgendamentoConferidoPor")
  agendamentosConcluidos       Agendamento[]           @relation("AgendamentoConcluido")
  agendamentosCancelados       Agendamento[]           @relation("AgendamentoCancelado")
  agendamentosVisualizados     Agendamento[]           @relation("AgendamentoVisualizado")
  agendamentosRevisados        Agendamento[]           @relation("AgendamentoRevisadoPor")
  observacoesAgenda            AgendamentoObservador[] @relation("AgendamentoObservadorUsuario")
  observacoesAgendaAdicionadas AgendamentoObservador[] @relation("AgendamentoObservadorAdicionadoPor")
  comentariosAgenda            AgendamentoComentario[] @relation("AgendamentoComentarioAutor")
  historicosAgenda             AgendamentoHistorico[]  @relation("AgendamentoHistoricoUsuario")
  recorrenciasCriadas          AgendamentoRecorrencia[] @relation("RecorrenciaCriadaPor")
  filtrosSalvos                AgendamentoFiltroSalvo[] @relation("AgendamentoFiltroSalvoUsuario")
  agendaCompartilhamentos      AgendaCompartilhamento[] @relation("AgendaCompartilhamentoUsuario")

  // Novos módulos
  calculosCriados   Calculo[]           @relation("CalculoCriadoPor")
  protocolosCriados Protocolo[]         @relation("ProtocoloCriadoPor")
  pecasIACriadas    PecaIA[]            @relation("PecaIACriadaPor")
  extratosCriados   ExtratoBancario[]   @relation("ExtratoCriadoPor")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

enum MfaLoginChallengeStatus {
  PENDENTE
  VERIFICADO
  EXPIRADO
}

model UserMfaConfig {
  id               String   @id @default(cuid())
  userId           String   @unique
  isEnabled        Boolean  @default(false)
  secretEncrypted  String
  enabledAt        DateTime?
  lastUsedAt       DateTime?
  enforcedByPolicy Boolean  @default(false)
  failedAttemptCount Int    @default(0)
  lastFailedAt      DateTime?
  lockedUntil       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isEnabled])
  @@map("users_mfa_config")
}

model MfaSetupChallenge {
  id              String   @id @default(cuid())
  userId          String   @unique
  secretEncrypted String
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("mfa_setup_challenges")
}

model MfaLoginChallenge {
  id           String                  @id @default(cuid())
  userId       String
  token        String                  @unique
  status       MfaLoginChallengeStatus @default(PENDENTE)
  attemptCount Int                     @default(0)
  expiresAt    DateTime
  verifiedAt   DateTime?
  createdAt    DateTime                @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
  @@map("mfa_login_challenges")
}

model UserRecoveryCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("user_recovery_codes")
}

model MfaTrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  deviceLabel String
  userAgent  String?
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, expiresAt])
  @@map("mfa_trusted_devices")
}

// =============================================================
// Ã°Å¸ÂÂ¢ ESCRITÓRIO & CONFIGURAÇÕES
// =============================================================

model Escritorio {
  id        String   @id @default(cuid())
  nome      String
  cnpj      String?  @unique
  endereco  String?
  cidade    String?
  estado    String?
  cep       String?
  telefone  String?
  email     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feriados               Feriado[]
  tiposAcao              TipoAcao[]
  fasesProcessuais       FaseProcessual[]
  centrosCusto           CentroCusto[]
  contasBancarias        ContaBancaria[]
  contactTags            ContactTag[]
  contactSegments        ContactSegment[]
  campaigns              Campaign[]
  crmListFolders         CRMListFolder[]
  crmLists               CRMList[]
  crmSavedViews          CRMSavedView[]
  crmPipelines           CRMPipeline[]
  crmLossReasons         CRMLossReason[]
  crmActivities          CRMActivity[]
  crmConflictChecks      CRMConflictCheck[]
  crmCommercialDocuments CRMCommercialDocument[]
  crmLgpdEvents          CRMLGPDEvent[]
  lgpdRequests           LgpdRequest[]
  automationFlows        AutomationFlow[]
  financeiroEscritorioLancamentos FinanceiroEscritorioLancamento[]
  casosFinanceiros               CasoFinanceiro[]
  funcionariosFinanceiros        FuncionarioFinanceiro[]

  categoriasDocumento CategoriaDocumento[] @relation("EscritorioCategorias")
  pastasDocumento     PastaDocumento[]     @relation("EscritorioPastas")
  documentos          Documento[]
  modelosDocumento    ModeloDocumento[]
  internalChatConversations InternalChatConversation[]
  internalChatParticipants  InternalChatParticipant[]
  internalChatMessages      InternalChatMessage[]
  internalChatAttachments   InternalChatAttachment[]
  internalChatPresence      InternalChatPresence[]

  @@map("escritorios")
}

model Feriado {
  id           String   @id @default(cuid())
  nome         String
  data         DateTime @db.Date
  recorrente   Boolean  @default(true)
  abrangencia  String   @default("NACIONAL")
  escritorioId String

  escritorio Escritorio @relation(fields: [escritorioId], references: [id])

  @@unique([data, escritorioId])
  @@index([data])
  @@map("feriados")
}

model TipoAcao {
  id           String  @id @default(cuid())
  nome         String
  grupo        String?
  descricao    String?
  ativo        Boolean @default(true)
  escritorioId String

  escritorio Escritorio @relation(fields: [escritorioId], references: [id])
  processos  Processo[]

  @@unique([nome, escritorioId])
  @@map("tipos_acao")
}

model FaseProcessual {
  id           String  @id @default(cuid())
  nome         String
  ordem        Int
  cor          String?
  ativo        Boolean @default(true)
  escritorioId String

  escritorio Escritorio         @relation(fields: [escritorioId], references: [id])
  processos  Processo[]
  workflows  WorkflowTemplate[]

  @@unique([nome, escritorioId])
  @@index([ordem])
  @@map("fases_processuais")
}

// =============================================================
// Ã°Å¸â€˜Â¥ CRM JURÍDICO (CLIENTES)
// =============================================================

enum TipoPessoa {
  FISICA
  JURIDICA
}

enum StatusCliente {
  PROSPECTO
  ATIVO
  INATIVO
  ARQUIVADO
}

enum LeadTemperatura {
  FRIO
  MORNO
  QUENTE
}

enum CRMRelationshipType {
  LEAD
  CLIENTE_POTENCIAL
  CLIENTE_ATIVO
  CLIENTE_INATIVO
  PARCEIRO
  FORNECEDOR
  PARTE_CONTRARIA
}

enum CRMInterestLevel {
  BAIXO
  MEDIO
  ALTO
}

model OrigemCliente {
  id   String @id @default(cuid())
  nome String @unique

  clientes Cliente[]

  @@map("origens_cliente")
}

model Cliente {
  id          String           @id @default(cuid())
  tipoPessoa  TipoPessoa       @default(FISICA)
  status      StatusCliente    @default(PROSPECTO)
  temperatura LeadTemperatura?

  nome           String
  cpf            String?   @unique
  rg             String?
  dataNascimento DateTime? @db.Date

  razaoSocial  String?
  cnpj         String? @unique
  nomeFantasia String?

  email    String?
  telefone String?
  celular  String?
  whatsapp String?

  endereco    String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?
  cep         String?

  origemId                String?
  observacoes             String?
  inadimplente            Boolean             @default(false)
  crmRelationship         CRMRelationshipType @default(LEAD)
  crmInterestLevel        CRMInterestLevel?
  crmScore                Int                 @default(0)
  marketingConsent        Boolean             @default(false)
  marketingConsentAt      DateTime?
  marketingConsentChannel CanalComunicacao?
  marketingConsentSource  String?
  dadosOrigem             String?
  dadosOrigemDetalhe      String?
  lastContactAt           DateTime?
  anonymizedAt            DateTime?
  areasJuridicas          String[]
  canalPreferido          CanalPreferido?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  origem         OrigemCliente?          @relation(fields: [origemId], references: [id])
  processos      Processo[]
  atendimentos   Atendimento[]
  honorarios     Honorario[]
  faturas        Fatura[]
  partesProcesso ParteProcesso[]
  phones         ClientPhone[]
  conversations  Conversation[]
  compromissos   Compromisso[]
  contactTags    ClienteContactTag[]
  segmentMembers ContactSegmentMember[]
  campaignsRecps CampaignRecipient[]
  crmCards       CRMCard[]
  crmActivities  CRMActivity[]
  crmConflicts   CRMConflictCheck[]
  crmDocuments   CRMCommercialDocument[]
  crmLgpdEvents  CRMLGPDEvent[]
  lgpdRequests   LgpdRequest[]
  flowExecutions FlowExecution[]
  casosFinanceiros CasoFinanceiro[]
  despesasProcessoFinanceiras DespesaProcesso[]
  financeiroEscritorioLancamentos FinanceiroEscritorioLancamento[]
  agendamentos    Agendamento[]   @relation("AgendamentoCliente")
  listMembers     CRMListMember[]

  // Novos módulos
  calculos Calculo[] @relation("CalculoCliente")
  pecasIA  PecaIA[]  @relation("PecaIACliente")

  // Dados estruturados
  enderecos Endereco[]
  contatos  ContatoCliente[]

  @@index([nome])
  @@index([cpf])
  @@index([cnpj])
  @@index([email])
  @@index([status])
  @@index([inadimplente])
  @@index([origemId])
  @@index([createdAt])
  @@index([lastContactAt])
  @@index([crmScore])
  @@index([status, crmScore])
  @@index([crmRelationship, status])
  @@map("clientes")
}

// =============================================================
// Ã°Å¸â€˜â€ EQUIPE JURÍDICA
// =============================================================

model Advogado {
  id              String  @id @default(cuid())
  userId          String  @unique
  oab             String
  seccional       String
  especialidades  String?
  comissaoPercent Float   @default(0)
  ativo           Boolean @default(true)

  user                User                    @relation(fields: [userId], references: [id])
  processos           Processo[]
  tarefas             Tarefa[]
  prazos              Prazo[]
  audiencias          Audiencia[]
  compromissos        Compromisso[]
  comissoes           Comissao[]
  atendimentos        Atendimento[]
  timeMembros         TimeMembro[]
  publicacoes         Publicacao[]
  distribuicoes       Distribuicao[]
  automacaoJobs       AutomacaoJob[]
  crmResponsavelCards CRMCard[]               @relation("CRMCardResponsavel")
  atribuicoesOrigem   ProcessoAtribuicaoLog[] @relation("ProcessoAtribuicaoOrigem")
  atribuicoesDestino  ProcessoAtribuicaoLog[] @relation("ProcessoAtribuicaoDestino")
  casosFinanceirosParticipacao CasoParticipante[]
  repassesHonorariosAdvogado   RepasseHonorario[] @relation("RepasseAdvogado")
  agendamentos                 Agendamento[]      @relation("AgendamentoResponsavel")

  @@index([oab])
  @@map("advogados")
}

// =============================================================
// Ã°Å¸Ââ€ºïÂ¸Â CATÁLOGO NACIONAL (TRIBUNAIS E FONTES)
// =============================================================

enum TribunalSourceType {
  DATAJUD
  DJEN
  DIARIO
  PORTAL
}

model Tribunal {
  id        String   @id @default(cuid())
  nome      String
  sigla     String   @unique
  ramo      String
  uf        String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sources TribunalSource[]

  @@index([ramo])
  @@index([uf])
  @@index([ativo])
  @@map("tribunais_catalogo")
}

model TribunalSource {
  id           String             @id @default(cuid())
  tribunalId   String
  sourceType   TribunalSourceType
  baseUrl      String?
  alias        String?
  enabled      Boolean            @default(false)
  requiresCert Boolean            @default(false)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tribunal Tribunal @relation(fields: [tribunalId], references: [id], onDelete: Cascade)

  @@unique([tribunalId, sourceType])
  @@index([sourceType, enabled])
  @@index([alias])
  @@map("tribunal_sources")
}

model Time {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  cor       String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  membros TimeMembro[]

  @@map("times")
}

model TimeMembro {
  id         String  @id @default(cuid())
  timeId     String
  advogadoId String
  lider      Boolean @default(false)

  time     Time     @relation(fields: [timeId], references: [id], onDelete: Cascade)
  advogado Advogado @relation(fields: [advogadoId], references: [id])

  @@unique([timeId, advogadoId])
  @@map("time_membros")
}

// =============================================================
// âÅ¡â€“ïÂ¸Â PROCESSOS
// =============================================================

enum TipoProcesso {
  JUDICIAL
  ADMINISTRATIVO
  CONSULTIVO
  SERVICO
  PROSPECCAO
}

enum StatusProcesso {
  PROSPECCAO
  CONSULTORIA
  AJUIZADO
  EM_ANDAMENTO
  AUDIENCIA_MARCADA
  SENTENCA
  RECURSO
  TRANSITO_JULGADO
  EXECUCAO
  ENCERRADO
  ARQUIVADO
}

enum ResultadoProcesso {
  GANHO
  PERDIDO
  ACORDO
  DESISTENCIA
  PENDENTE
}

model Processo {
  id        String            @id @default(cuid())
  numeroCnj String?           @unique
  tipo      TipoProcesso      @default(JUDICIAL)
  status    StatusProcesso    @default(EM_ANDAMENTO)
  resultado ResultadoProcesso @default(PENDENTE)

  tipoAcaoId       String?
  faseProcessualId String?
  tribunal         String?
  vara             String?
  comarca          String?
  foro             String?
  objeto           String?
  valorCausa       Decimal? @db.Decimal(15, 2)

  valorContingencia Decimal? @db.Decimal(15, 2)
  riscoContingencia String?

  grau            String?  // PRIMEIRO | SEGUNDO | STJ | STF | TRABALHISTA | ESPECIAL
  segredoJustica  Boolean  @default(false)

  dataDistribuicao DateTime? @db.Date
  dataEncerramento DateTime? @db.Date

  advogadoId String
  clienteId  String?

  observacoes            String?
  dataUltimaMovimentacao DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tipoAcao       TipoAcao?       @relation(fields: [tipoAcaoId], references: [id])
  faseProcessual FaseProcessual? @relation(fields: [faseProcessualId], references: [id])
  advogado       Advogado        @relation(fields: [advogadoId], references: [id])
  cliente        Cliente?        @relation(fields: [clienteId], references: [id])

  partes          ParteProcesso[]
  movimentacoes   Movimentacao[]
  prazos          Prazo[]
  tarefas         Tarefa[]
  audiencias      Audiencia[]
  documentos      Documento[]
  honorarios      Honorario[]
  contasPagar     ContaPagar[]
  casosFinanceiros CasoFinanceiro[]
  despesasFinanceirasProcesso DespesaProcesso[]
  financeiroEscritorioLancamentos FinanceiroEscritorioLancamento[]
  publicacoes     Publicacao[]
  atendimentos    Atendimento[]
  vinculosOrigem  ProcessoVinculado[]     @relation("ProcessoOrigem")
  vinculosDestino ProcessoVinculado[]     @relation("ProcessoDestino")
  conversations   Conversation[]
  crmProcessLinks CRMCardProcessLink[]
  crmActivities   CRMActivity[]
  crmDocuments    CRMCommercialDocument[]
  atribuicoesLog  ProcessoAtribuicaoLog[]
  flowExecutions  FlowExecution[]
  agendamentos    Agendamento[]           @relation("AgendamentoProcesso")

  // Novos módulos
  calculos   Calculo[]   @relation("CalculoProcesso")
  protocolos Protocolo[] @relation("ProtocoloProcesso")
  pecasIA    PecaIA[]    @relation("PecaIAProcesso")

  @@index([numeroCnj])
  @@index([status])
  @@index([tipo])
  @@index([advogadoId])
  @@index([clienteId])
  @@index([faseProcessualId])
  @@index([tipoAcaoId])
  @@index([dataDistribuicao])
  @@index([dataUltimaMovimentacao])
  @@index([createdAt])
  @@index([status, advogadoId])
  @@index([status, clienteId])
  @@index([tribunal, vara])
  @@map("processos")
}

model ProcessoAtribuicaoLog {
  id                String   @id @default(cuid())
  processoId        String
  fromAdvogadoId    String?
  toAdvogadoId      String
  automatico        Boolean  @default(false)
  modoDistribuicao  String?
  mesmaEquipe       Boolean  @default(false)
  scoreOrigem       Float?
  scoreDestino      Float?
  motivo            String?
  triggeredByUserId String?
  createdAt         DateTime @default(now())

  processo        Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  fromAdvogado    Advogado? @relation("ProcessoAtribuicaoOrigem", fields: [fromAdvogadoId], references: [id])
  toAdvogado      Advogado  @relation("ProcessoAtribuicaoDestino", fields: [toAdvogadoId], references: [id])
  triggeredByUser User?     @relation("ProcessoAtribuicaoExecutadaPor", fields: [triggeredByUserId], references: [id])

  @@index([processoId])
  @@index([fromAdvogadoId])
  @@index([toAdvogadoId])
  @@index([triggeredByUserId])
  @@index([createdAt])
  @@map("processo_atribuicao_logs")
}

enum TipoParte {
  AUTOR
  REU
  TERCEIRO
  TESTEMUNHA
  PERITO
  ASSISTENTE_TECNICO
}

model ParteProcesso {
  id         String    @id @default(cuid())
  processoId String
  clienteId  String?
  tipoParte  TipoParte

  nome     String?
  cpfCnpj  String?
  advogado String?

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  cliente  Cliente? @relation(fields: [clienteId], references: [id])

  @@index([processoId])
  @@map("partes_processo")
}

model Movimentacao {
  id         String   @id @default(cuid())
  processoId String
  data       DateTime @db.Date
  descricao  String
  tipo       String?
  fonte      String?
  createdAt  DateTime @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([processoId])
  @@index([data])
  @@index([processoId, data])
  @@map("movimentacoes")
}

enum TipoVinculo {
  CONEXAO
  CONTINENCIA
  RECURSO
  INCIDENTE
  RELACIONADO
}

model ProcessoVinculado {
  id                String      @id @default(cuid())
  processoOrigemId  String
  processoDestinoId String
  tipoVinculo       TipoVinculo

  processoOrigem  Processo @relation("ProcessoOrigem", fields: [processoOrigemId], references: [id])
  processoDestino Processo @relation("ProcessoDestino", fields: [processoDestinoId], references: [id])

  @@unique([processoOrigemId, processoDestinoId])
  @@map("processos_vinculados")
}

// =============================================================
// Ã°Å¸â€œâ€¦ PRAZOS, AUDIÊNCIAS & AGENDA
// =============================================================

enum StatusPrazo {
  PENDENTE
  CONCLUIDO
  VENCIDO
}

enum TipoContagem {
  DIAS_UTEIS
  DIAS_CORRIDOS
}

enum OrigemPrazo {
  MANUAL
  PUBLICACAO_IA
}

model Prazo {
  id         String @id @default(cuid())
  processoId String
  advogadoId String

  descricao          String
  dataFatal          DateTime     @db.Date
  dataCortesia       DateTime?    @db.Date
  tipoContagem       TipoContagem @default(DIAS_UTEIS)
