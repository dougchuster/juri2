}

model AgendamentoRecorrencia {
  id             String                @id @default(cuid())
  frequencia     FrequenciaRecorrencia
  intervalo      Int                   @default(1) // a cada X (dias/semanas/meses)
  diasSemana     Int[] // [1,3,5] = seg, qua, sex
  diaMes         Int? // dia do mes (para MENSAL)
  dataTermino    DateTime?
  maxOcorrencias Int?
  apenasUteis    Boolean               @default(false)
  criadoPorId    String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  criadoPor  User          @relation("RecorrenciaCriadaPor", fields: [criadoPorId], references: [id])
  instancias Agendamento[]

  @@map("agendamento_recorrencias")
}

model AgendamentoFiltroSalvo {
  id        String   @id @default(cuid())
  userId    String
  nome      String
  filtros   Json // { status: [...], tipo: [...], responsavelId: "...", etc }
  padrao    Boolean  @default(false)
  createdAt DateTime @default(now())

  usuario User @relation("AgendamentoFiltroSalvoUsuario", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("agendamento_filtros_salvos")
}

model AgendaCompartilhamento {
  id         String    @id @default(cuid())
  userId     String // dono da agenda compartilhada
  token      String    @unique // token unico no link
  tipoAcesso String // "PUBLICO", "AUTENTICADO", "ICAL_FEED"
  filtros    Json? // tipos, periodo, processo filtrados
  expiraEm   DateTime?
  ativo      Boolean   @default(true)
  acessos    Int       @default(0) // contador de acessos
  createdAt  DateTime  @default(now())

  usuario User @relation("AgendaCompartilhamentoUsuario", fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("agenda_compartilhamentos")
}

// =============================================================
// 📝 CÁLCULOS JURÍDICOS (Módulo 15)
// =============================================================

model Calculo {
  id          String   @id @default(cuid())
  tipo        String   // MONETARIO | PREVIDENCIARIO | TRABALHISTA
  nome        String
  parametros  Json
  resultado   Json?
  processoId  String?
  clienteId   String?
  criadoPorId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  processo  Processo? @relation("CalculoProcesso", fields: [processoId], references: [id], onDelete: SetNull)
  cliente   Cliente?  @relation("CalculoCliente", fields: [clienteId], references: [id], onDelete: SetNull)
  criadoPor User      @relation("CalculoCriadoPor", fields: [criadoPorId], references: [id])

  @@index([processoId])
  @@index([clienteId])
  @@index([criadoPorId])
  @@index([tipo])
  @@index([createdAt])
  @@map("calculos")
}

// =============================================================
// 📦 PROTOCOLOS (Módulo 16)
// =============================================================

model Protocolo {
  id                String    @id @default(cuid())
  dataEntrada       DateTime  @default(now())
  dataPrevistaSaida DateTime?
  prazo             Int?
  tipo              String    @default("ENVIO")   // ENVIO | RECEBIMENTO | RETORNO
  status            String    @default("PENDENTE") // PENDENTE | TRANSITO | ENTREGUE | DEVOLVIDO
  codigoBarras      String?
  remetente         String
  destinatario      String
  localizacao       String?
  observacoes       String?
  processoId        String?
  criadoPorId       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  processo  Processo?          @relation("ProtocoloProcesso", fields: [processoId], references: [id], onDelete: SetNull)
  criadoPor User               @relation("ProtocoloCriadoPor", fields: [criadoPorId], references: [id])
  historico ProtocoloHistorico[]

  @@index([processoId])
  @@index([criadoPorId])
  @@index([status])
  @@index([tipo])
  @@index([dataEntrada])
  @@map("protocolos")
}

model ProtocoloHistorico {
  id          String   @id @default(cuid())
  protocoloId String
  status      String
  observacao  String?
  criadoPorId String?
  createdAt   DateTime @default(now())

  protocolo Protocolo @relation(fields: [protocoloId], references: [id], onDelete: Cascade)

  @@index([protocoloId])
  @@map("protocolo_historico")
}

// =============================================================
// ✍️ PEÇAS COM IA (Módulo 10)
// =============================================================

model PecaIA {
  id             String   @id @default(cuid())
  tipoPeca       String
  area           String   // CIVEL | TRABALHISTA | FAMILIA | PREVIDENCIARIO | CONTRATO
  fatosInput     String   @db.Text
  conteudo       String?  @db.Text
  status         String   @default("RASCUNHO") // RASCUNHO | GERADA | REVISADA | FINALIZADA
  processoId     String?
  clienteId      String?
  criadoPorId    String
  creditosUsados Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  processo  Processo? @relation("PecaIAProcesso", fields: [processoId], references: [id], onDelete: SetNull)
  cliente   Cliente?  @relation("PecaIACliente", fields: [clienteId], references: [id], onDelete: SetNull)
  criadoPor User      @relation("PecaIACriadaPor", fields: [criadoPorId], references: [id])

  @@index([processoId])
  @@index([clienteId])
  @@index([criadoPorId])
  @@index([status])
  @@index([tipoPeca])
  @@index([createdAt])
  @@map("pecas_ia")
}

// =============================================================
// 🏠 ENDEREÇOS (§26 — tabela enderecos)
// =============================================================

enum TipoEndereco {
  PRINCIPAL
  COBRANCA
  CORRESPONDENCIA
  COMERCIAL
  OUTRO
}

model Endereco {
  id          String       @id @default(cuid())
  clienteId   String
  tipo        TipoEndereco @default(PRINCIPAL)
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?      @db.Char(2)
  pais        String?      @default("BR")
  principal   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([cep])
  @@map("enderecos")
}

// =============================================================
// 📞 CONTATOS DO CLIENTE (§26 — tabela contatos_cliente)
// =============================================================

enum TipoContato {
  EMAIL
  TELEFONE
  CELULAR
  WHATSAPP
  SITE
  LINKEDIN
  INSTAGRAM
  FACEBOOK
  OUTRO
}

model ContatoCliente {
  id        String      @id @default(cuid())
  clienteId String
  tipo      TipoContato
  valor     String
  descricao String?     // ex: "Comercial", "Pessoal"
  principal Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([tipo])
  @@map("contatos_cliente")
}

// =============================================================
// 🗂️ KANBAN — QUADROS E COLUNAS (§26)
// =============================================================

model KanbanQuadro {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  cor       String?  @default("#6366f1")
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  colunas KanbanColuna[]
  tarefas Tarefa[]

  @@map("kanban_quadros")
}

model KanbanColuna {
  id         String   @id @default(cuid())
  quadroId   String
  nome       String
  ordem      Int      @default(0)
  cor        String?
  limiteWip  Int?     // Work-in-progress limit (null = sem limite)
  statusMapa String?  // Status da Tarefa que esta coluna representa
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  quadro  KanbanQuadro @relation(fields: [quadroId], references: [id], onDelete: Cascade)
  tarefas Tarefa[]

  @@index([quadroId])
  @@index([ordem])
  @@map("kanban_colunas")
}

// =============================================================
// ⚙️ CAMPOS PERSONALIZADOS (§26)
// =============================================================

enum TipoCampo {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  DATETIME
  SELECT
  MULTISELECT
  BOOLEAN
  URL
  EMAIL
  PHONE
  CURRENCY
}

enum EntidadeCampo {
  CLIENTE
  PROCESSO
  TAREFA
  ATENDIMENTO
  DOCUMENTO
}

model CampoPersonalizado {
  id          String        @id @default(cuid())
  entidade    EntidadeCampo
  nome        String        // chave interna (snake_case)
  label       String        // exibição para o usuário
  tipo        TipoCampo
  opcoes      Json?         // [{value: string, label: string}] para SELECT/MULTISELECT
  obrigatorio Boolean       @default(false)
  ordem       Int           @default(0)
  ativo       Boolean       @default(true)
  placeholder String?
  ajuda       String?       // tooltip / instrução
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  valores CampoValor[]

  @@unique([entidade, nome])
  @@index([entidade])
  @@index([ativo])
  @@map("campos_personalizados")
}

model CampoValor {
  id         String   @id @default(cuid())
  campoId    String
  entidadeId String   // ID do registro (cliente, processo, tarefa, etc.)
  valor      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campo CampoPersonalizado @relation(fields: [campoId], references: [id], onDelete: Cascade)

  @@unique([campoId, entidadeId])
  @@index([campoId])
  @@index([entidadeId])
  @@map("campos_valores")
}
