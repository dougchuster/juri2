enum RuleTarget {
  CLIENTE
  RESPONSAVEL
  AMBOS
}

model NotificationRule {
  id         String            @id @default(cuid())
  name       String
  eventType  EventType
  canal      CanalComunicacao?
  templateId String
  target     RuleTarget
  isActive   Boolean           @default(true)

  triggerOffset Int?
  sendHourStart Int?    @default(8)
  sendHourEnd   Int?    @default(18)
  workdaysOnly  Boolean @default(true)

  maxRetries    Int @default(3)
  retryInterval Int @default(60)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template MessageTemplate    @relation(fields: [templateId], references: [id])
  jobs     CommunicationJob[]

  @@map("notification_rules")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model CommunicationJob {
  id     String           @id @default(cuid())
  ruleId String?
  canal  CanalComunicacao
  status JobStatus        @default(PENDING)

  recipientPhone String?
  recipientEmail String?
  clienteId      String?
  userId         String?

  templateId  String?
  subject     String?
  content     String  @db.Text
  contentHtml String? @db.Text
  variables   Json?
  attachments Json?

  processoId String?
  prazoId    String?
  tarefaId   String?
  compromissoId String?

  scheduledFor  DateTime  @default(now())
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  lastAttemptAt DateTime?
  completedAt   DateTime?
  errorMessage  String?
  providerMsgId String?

  correlationId String   @default(cuid())
  createdAt     DateTime @default(now())

  rule        NotificationRule? @relation(fields: [ruleId], references: [id])
  compromisso Compromisso?     @relation(fields: [compromissoId], references: [id])

  @@index([status])
  @@index([scheduledFor])
  @@index([status, scheduledFor])
  @@index([correlationId])
  @@index([compromissoId])
  @@map("communication_jobs")
}

model WebhookEvent {
  id           String    @id @default(cuid())
  source       String
  eventType    String
  payload      Json
  processed    Boolean   @default(false)
  processedAt  DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([source, eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_events")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

