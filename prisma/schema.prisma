model ContactSegment {
  id               String    @id @default(cuid())
  escritorioId     String
  name             String
  description      String?
  rules            Json      @default("[]")
  isDynamic        Boolean   @default(true)
  memberCount      Int       @default(0)
  lastCalculatedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members    ContactSegmentMember[]
  campaigns  Campaign[]
  escritorio Escritorio             @relation(fields: [escritorioId], references: [id], onDelete: Cascade)

  @@index([escritorioId])
  @@map("contact_segments")
}

model ContactSegmentMember {
  segmentId String
  clienteId String
  addedAt   DateTime @default(now())

  segment ContactSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  cliente Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@id([segmentId, clienteId])
  @@index([segmentId])
  @@index([clienteId])
  @@map("contact_segment_members")
}

