// =============================================================
// Ã°Å¸Â¤â€“ AUTOMAÇÃO NACIONAL (JOBS + AUDITORIA)
// =============================================================

enum StatusAutomacaoJob {
  QUEUED
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
  CANCELED
}

enum JobExecutionAttemptSourceType {
  AUTOMACAO_NACIONAL_JOB
  FLOW_EXECUTION
}

enum JobExecutionAttemptTriggerSource {
  SYSTEM
  MANUAL_RETRY
  MANUAL_CANCEL
}

enum JobExecutionAttemptStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum StatusAutomacaoLog {
  QUEUED
  RUNNING
  SUCCESS
  SKIPPED
  FAILED
}

model AutomacaoJob {
  id                    String             @id @default(cuid())
  advogadoId            String
  modo                  String             @default("NACIONAL")
  status                StatusAutomacaoJob @default(QUEUED)
  janelaInicio          DateTime?
  janelaFim             DateTime?
  startedAt             DateTime?
  finishedAt            DateTime?
  erroResumo            String?
  totalTribunais        Int                @default(0)
  sucessoTribunais      Int                @default(0)
  falhaTribunais        Int                @default(0)
  publicacoesCapturadas Int                @default(0)
  publicacoesImportadas Int                @default(0)
  prazosCriados         Int                @default(0)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  advogado Advogado       @relation(fields: [advogadoId], references: [id], onDelete: Cascade)
  logs     AutomacaoLog[]

  @@index([advogadoId, createdAt])
  @@index([status, createdAt])
  @@map("automacao_jobs")
}

model JobExecutionAttempt {
  id             String                           @id @default(cuid())
  sourceType     JobExecutionAttemptSourceType
  sourceId       String
  chainKey       String
  attemptNumber  Int
  triggerSource  JobExecutionAttemptTriggerSource @default(SYSTEM)
  retryOfSourceId String?
  triggeredById  String?
  reason         String?
  status         JobExecutionAttemptStatus        @default(QUEUED)
  errorMessage   String?
  payloadSnapshot Json?
  resultSnapshot Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt

  triggeredBy User? @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([sourceType, sourceId])
  @@index([chainKey, attemptNumber])
  @@index([retryOfSourceId])
  @@index([triggeredById])
  @@map("job_execution_attempts")
}

model AutomacaoLog {
  id         String             @id @default(cuid())
  jobId      String
  tribunal   String
  sourceType String
  inicio     DateTime
  fim        DateTime?
  status     StatusAutomacaoLog @default(QUEUED)
  erro       String?
  meta       Json?
  createdAt  DateTime           @default(now())

  job AutomacaoJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, tribunal])
  @@index([jobId, status])
  @@index([sourceType])
  @@map("automacao_logs")
}

