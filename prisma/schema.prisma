// =============================================================
// Ã°Å¸â€œâ€¦ INTEGRAÇÕES DE CALENDÁRIO (Google / Outlook)
// =============================================================

enum CalendarProvider {
  GOOGLE
  OUTLOOK
}

model CalendarIntegration {
  id       String           @id @default(cuid())
  userId   String
  provider CalendarProvider
  email    String

  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  tokenExpiry  DateTime?
  calendarId   String? // e.g. "primary" for Google, calendar ID for Outlook
  enabled      Boolean   @default(true)
  lastSyncAt   DateTime?
  syncErrors   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  syncedEvents CalendarEvent[]

  @@unique([userId, provider])
  @@index([userId])
  @@map("calendar_integrations")
}

model CalendarEvent {
  id              String @id @default(cuid())
  integrationId   String
  externalEventId String // Google/Outlook event ID

  // Link to internal entities (one of these will be set)
  prazoId       String?
  audienciaId   String?
  compromissoId String?

  title       String
  description String?   @db.Text
  startAt     DateTime
  endAt       DateTime?
  location    String?
  allDay      Boolean   @default(false)

  lastSyncAt    DateTime @default(now())
  syncDirection String   @default("outbound") // "outbound" = system->calendar, "inbound" = calendar->system
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agendamentoId String?
  agendamento   Agendamento? @relation("AgendamentoCalendarEvents", fields: [agendamentoId], references: [id])

  integration CalendarIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalEventId])
  @@index([prazoId])
  @@index([audienciaId])
  @@index([compromissoId])
  @@index([integrationId])
  @@index([agendamentoId])
  @@map("calendar_events")
}

// =============================================================
// Ã°Å¸â€â€ NOTIFICAÇÕES
// =============================================================

enum TipoNotificacao {
  PRAZO_VENCENDO
  PRAZO_VENCIDO
  TAREFA_ATRIBUIDA
  TAREFA_REATRIBUIDA
  FATURA_VENCENDO
  FATURA_VENCIDA
  AUDIENCIA_PROXIMA
  ANIVERSARIANTE
  PROCESSO_MOVIMENTACAO
  SISTEMA
  MENSAGEM_RECEBIDA
  ENVIO_FALHOU
}

model Notificacao {
  id        String          @id @default(cuid())
  userId    String
  tipo      TipoNotificacao
  titulo    String
  mensagem  String
  lida      Boolean         @default(false)
  linkUrl   String?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, lida])
  @@index([createdAt])
  @@map("notificacoes")
}

// =============================================================
// Ã°Å¸â€™Â¬ COMUNICAÇÃO (WhatsApp + E-mail)
// =============================================================

enum WhatsAppOptIn {
  OPTED_IN
  OPTED_OUT
  UNKNOWN
}

model ClientPhone {
  id             String        @id @default(cuid())
  clienteId      String
  phone          String // formato E.164: +5562999999999
  phoneDisplay   String // formato amigável: (62) 99999-9999
  label          String        @default("principal")
  isWhatsApp     Boolean       @default(true)
  isPrimary      Boolean       @default(false)
  whatsappOptIn  WhatsAppOptIn @default(OPTED_IN)
  lastContactAt  DateTime?
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime      @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([phone])
  @@index([clienteId])
  @@index([phone])
  @@map("client_phones")
}

enum CanalComunicacao {
  WHATSAPP
  EMAIL
}

enum CanalPreferido {
  EMAIL
  WHATSAPP
  AMBOS
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum AttendanceAutomationTriggerType {
  AFTER_HOURS
  KEYWORD
  ALWAYS
}

enum AttendanceAutomationSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum AttendanceAutomationEventType {
  INBOUND_EVALUATED
  FLOW_MATCHED
  AUTO_REPLIED
  AI_REPLIED
  FALLBACK_REPLIED
  ERROR
  SESSION_PAUSED
}

model Conversation {
  id            String             @id @default(cuid())
  clienteId     String
  canal         CanalComunicacao
  status        ConversationStatus @default(OPEN)
  subject       String?
  processoId    String?
  atendimentoId String?
  assignedToId  String?
  lastMessageAt DateTime?
  unreadCount   Int                @default(0)
  iaDesabilitada Boolean           @default(false)
  iaDesabilitadaEm DateTime?
  iaDesabilitadaPor String?
  autoAtendimentoPausado Boolean   @default(false)
  pausadoAte    DateTime?
  motivoPausa   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  cliente    Cliente   @relation(fields: [clienteId], references: [id])
  processo   Processo? @relation(fields: [processoId], references: [id])
  atendimento Atendimento? @relation(fields: [atendimentoId], references: [id])
  assignedTo User?     @relation(fields: [assignedToId], references: [id])
  messages   Message[]
  automationSessions AttendanceAutomationSession[]
  automationEvents   AttendanceAutomationEvent[]

  @@index([clienteId])
  @@index([status])
  @@index([canal])
  @@index([atendimentoId])
  @@index([lastMessageAt])
  @@map("conversations")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  RECEIVED
  FAILED
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  canal          CanalComunicacao

  content     String
  contentHtml String? @db.Text

  templateId   String?
  templateVars Json?

  status        MessageStatus @default(QUEUED)
  providerMsgId String?       @unique
  errorMessage  String?

  senderPhone String?
  senderName  String?

  processoId String?
  prazoId    String?
  tarefaId   String?

  sentById    String?
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  receivedAt  DateTime?
  createdAt   DateTime  @default(now())

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  MessageAttachment[]

  @@index([conversationId])
  @@index([providerMsgId])
  @@index([status])
  @@index([createdAt])
  @@map("messages")
}

model MessageAttachment {
  id          String   @id @default(cuid())
  messageId   String
  fileName    String
  mimeType    String
  fileSize    Int?
  fileUrl     String
  providerUrl String?
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

model MessageTemplate {
  id          String            @id @default(cuid())
  name        String            @unique
  canal       CanalComunicacao?
  category    String
  subject     String?
  content     String            @db.Text
  contentHtml String?           @db.Text
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  rules     NotificationRule[]
  campaigns Campaign[]

  @@map("message_templates")
}

model AttendanceAutomationFlow {
  id                   String                           @id @default(cuid())
  name                 String
  description          String?                          @db.Text
  canal                CanalComunicacao                 @default(WHATSAPP)
  isActive             Boolean                          @default(true)
  priority             Int                              @default(100)
  triggerType          AttendanceAutomationTriggerType  @default(KEYWORD)
  keywordMode          String                           @default("ANY")
  keywords             Json                             @default("[]")
  businessHoursStart   Int                              @default(8)
  businessHoursEnd     Int                              @default(18)
  timezone             String                           @default("America/Sao_Paulo")
  initialReplyTemplate String                           @db.Text
  followUpReplyTemplate String?                         @db.Text
  aiEnabled            Boolean                          @default(false)
  aiModel              String                           @default("kimi-k2.5")
  aiInstructions       String?                          @db.Text
  humanizedStyle       String?                          @db.Text
  maxAutoReplies       Int                              @default(3)
  cooldownMinutes      Int                              @default(15)
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt

  sessions AttendanceAutomationSession[]
  events   AttendanceAutomationEvent[]

  @@index([isActive, canal, priority])
  @@map("attendance_automation_flows")
}

model AttendanceAutomationSession {
  id                 String                           @id @default(cuid())
  conversationId     String
  flowId             String
  status             AttendanceAutomationSessionStatus @default(ACTIVE)
  replyCount         Int                              @default(0)
  lastInboundAt      DateTime?
  lastReplyAt        DateTime?
  lastTriggerReason  String?
  lastInboundSummary String?                          @db.Text
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt

  conversation Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  flow         AttendanceAutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  events       AttendanceAutomationEvent[]

  @@unique([conversationId, flowId])
  @@index([flowId, status])
  @@index([conversationId, status])
  @@map("attendance_automation_sessions")
}

model AttendanceAutomationEvent {
  id             String                        @id @default(cuid())
  conversationId String
  flowId         String?
  sessionId      String?
  messageId      String?
  eventType      AttendanceAutomationEventType
  content        String?                       @db.Text
  metadata       Json?
  createdAt      DateTime                      @default(now())

  conversation Conversation                 @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  flow         AttendanceAutomationFlow?    @relation(fields: [flowId], references: [id], onDelete: SetNull)
  session      AttendanceAutomationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([messageId, eventType])
  @@index([conversationId, createdAt])
  @@index([flowId, createdAt])
  @@map("attendance_automation_events")
}

enum InternalChatConversationType {
  DIRECT
  GROUP
}

enum InternalChatMessageType {
  TEXT
  FILE
  AUDIO
  SYSTEM
}

enum InternalChatAttachmentKind {
  FILE
  AUDIO
}

enum InternalChatPresenceStatus {
  ONLINE
  AWAY
  BUSY
  OFFLINE
}

model InternalChatConversation {
  id            String                        @id @default(cuid())
  escritorioId  String
  type          InternalChatConversationType @default(DIRECT)
  createdById   String
  directKey     String?                       @unique
  title         String?
  description   String?                       @db.Text
  avatarUrl     String?
  isTeamGroup   Boolean                       @default(false)
  lastMessageId String?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt
  archivedAt    DateTime?

  escritorio   Escritorio               @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  createdBy    User                     @relation("InternalChatCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  participants InternalChatParticipant[]
  messages     InternalChatMessage[]
  lastMessage  InternalChatMessage?     @relation("InternalChatLastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)

  @@index([escritorioId, updatedAt])
  @@index([escritorioId, type])
  @@index([escritorioId, isTeamGroup])
  @@map("internal_chat_conversations")
}

model InternalChatParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  escritorioId   String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?
  archivedAt     DateTime?
  mutedUntil     DateTime?

  conversation InternalChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  escritorio   Escritorio               @relation(fields: [escritorioId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, escritorioId])
  @@index([conversationId, escritorioId])
  @@map("internal_chat_participants")
}

model InternalChatMessage {
  id             String                   @id @default(cuid())
  conversationId String
  escritorioId   String
  senderId       String
  type           InternalChatMessageType
  text           String?                  @db.Text
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?

  conversation        InternalChatConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender              User                       @relation("InternalChatMessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  escritorio          Escritorio                 @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  attachments         InternalChatAttachment[]
  reads               InternalChatRead[]
  lastForConversation InternalChatConversation[] @relation("InternalChatLastMessage")

  @@index([conversationId, createdAt])
  @@index([escritorioId, senderId])
  @@map("internal_chat_messages")
}

model InternalChatAttachment {
  id              String                      @id @default(cuid())
  messageId       String
  escritorioId    String
  kind            InternalChatAttachmentKind
  storageKey      String
  fileUrl         String
  originalName    String
  mimeType        String
  sizeBytes       Int
  durationSeconds Int?
  metadataJson    Json?
  createdAt       DateTime                    @default(now())

  message    InternalChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  escritorio Escritorio          @relation(fields: [escritorioId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([escritorioId, kind])
  @@map("internal_chat_attachments")
}

model InternalChatRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message InternalChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@map("internal_chat_reads")
}

model InternalChatPresence {
  id             String                       @id @default(cuid())
  escritorioId   String
  userId         String                       @unique
  manualStatus   InternalChatPresenceStatus?
  lastSeenAt     DateTime?
  lastActivityAt DateTime?
  updatedAt      DateTime                     @updatedAt

  escritorio Escritorio @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([escritorioId, manualStatus])
  @@map("internal_chat_presence")
}

enum EventType {
  PRAZO_D5
  PRAZO_D3
  PRAZO_D1
  PRAZO_D0
  PROCESSO_STATUS_CHANGED
  PROCESSO_MOVIMENTACAO
  TAREFA_CRIADA
  TAREFA_VENCIDA
  TAREFA_CONCLUIDA
  PIPELINE_ETAPA_CHANGED
  FATURA_VENCENDO
  FATURA_VENCIDA
  REUNIAO_CONFIRMACAO_CLIENTE
  REUNIAO_LEMBRETE_CLIENTE_D1
  REUNIAO_LEMBRETE_CLIENTE_H1
  REUNIAO_LEMBRETE_RESPONSAVEL_D1
  REUNIAO_LEMBRETE_RESPONSAVEL_H1
  REUNIAO_CONFIRMADA
  REUNIAO_REMARCACAO_SOLICITADA
  REUNIAO_CANCELADA
