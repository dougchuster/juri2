enum LegalAgentConversationStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum LegalAgentMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model LegalAgentConversation {
  id                  String                       @id @default(cuid())
  userId              String
  agentId             String
  title               String?
  status              LegalAgentConversationStatus @default(ACTIVE)
  memorySummary       String?                      @db.Text
  summaryMessageCount Int                          @default(0)
  memoryUpdatedAt     DateTime?
  lastMessageAt       DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages LegalAgentMessage[]

  @@index([userId, agentId, status])
  @@index([userId, lastMessageAt])
  @@index([agentId, status])
  @@map("legal_agent_conversations")
}

model LegalAgentMessage {
  id             String                @id @default(cuid())
  conversationId String
  role           LegalAgentMessageRole
  content        String                @db.Text
  model          String?
  promptChars    Int?
  createdAt      DateTime              @default(now())

  conversation LegalAgentConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  LegalAgentMessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([role])
  @@map("legal_agent_messages")
}

model LegalAgentMessageAttachment {
  id               String   @id @default(cuid())
  messageId        String
  fileName         String
  mimeType         String
  fileSize         Int?
  fileUrl          String
  extractedText    String?  @db.Text
  extractedChars   Int      @default(0)
  extractionStatus String   @default("unsupported")
  extractionMethod String   @default("none")
  warning          String?
  createdAt        DateTime @default(now())

  message LegalAgentMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("legal_agent_message_attachments")
}

